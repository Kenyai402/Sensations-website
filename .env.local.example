# The Sensations — Environment Variables

# HOW TO GET RESEND WORKING:
#   1. Go to https://resend.com and create a free account
#   2. Click "API Keys" → "Create API Key" → copy it below
#   3. Set CONTACT_EMAIL to the inbox that should receive messages
#   4. On Resend, verify your sending domain (or use the Resend test domain for now)
#   5. Restart the dev server: pnpm dev


RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=hello@sensations.ke
